# Copy to .env and fill in. Collectors without their key are skipped automatically.
# Load with:  set -a; source .env; set +a    (or use direnv / uv's env handling)

# --- live collectors ---
SHODAN_API_KEY=
CENSYS_PAT=
MALLORY_API_KEY=
HIBP_API_KEY=
# HIBP breacheddomain lookups only cover domains verified on your HIBP account.
# Tune to your subscription's rate limit (seconds between domain lookups):
HIBP_REQUEST_DELAY=1.6
VT_API_KEY=
# VirusTotal free tier is ~4 req/min. Seconds to pace each call (lower if premium):
VT_REQUEST_DELAY=15
VT_PASSIVE_DNS=1            # set 0 to skip passive-DNS calls (halves VT credit use)
VT_DNS_LOOKBACK_DAYS=30
LEAKLOOKUP_API_KEY=
# Leak-Lookup is credit-metered; seconds to pace each domain search:
LEAKLOOKUP_REQUEST_DELAY=2
# crt.sh, RansomLook and NVD-KEV need no key.

# --- alerting ---
# Slack incoming webhook. If unset, --dry-run behaviour: the payload is printed.
SLACK_WEBHOOK_URL=
