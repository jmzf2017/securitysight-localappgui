# Local paths to your two GitHub clones — used by `./runssp update` and the
# cloud part of `./runssp reset`. Copy this file to `.ssp.env` (gitignored) and
# fill in your paths. Not needed for run / dashboard / test / local reset.
SSP_PUBLIC_DIR="/absolute/path/to/securitysight"
SSP_PRIVATE_DIR="/absolute/path/to/securitysight-private"

# Optional: substring (case-insensitive) that identifies the PRIVATE repo by
# name for Invariant D. The private clone's `origin` repo name must contain it;
# the public clone's must not. Default `private` fits securitysight-private.
# SSP_PRIVATE_REPO_PATTERN="private"
